    "test:r20:qa": "node --test \"tests/application/r20-protocol-phase-e-closure-gate.test.js\" \"tests/application/action-contract-parity.test.js\" \"tests/application/turn-policies-schema-compensation.test.js\" \"tests/application/get-write-contract-bundle.test.js\" \"tests/application/get-tool-schema-lifecycle.test.js\" \"tests/application/anchor-write-guard.test.js\" \"tests/application/anchor-error-feedback.test.js\" \"tests/application/r20-governance-metrics-wiring.test.js\" \"tests/application/r20-governance-baseline-script.test.js\" \"tests/application/r11-command-contract-snapshot.test.js\" \"tests/application/mcp-tool-schema-minimal.test.js\" \"tests/domain/validators.anchor-hardcut.test.js\" \"tests/domain/validators.composite-action.test.js\"",
