    "gate:r10-contract-snapshot": "node scripts/r10-contract-snapshot-guard.js",
    "gate:r10-docs": "node scripts/r10-doc-index-guard.js",
    "gate:r11-command-boundary": "node scripts/r11-command-boundary-guard.js",
    "gate:r16-wire": "node scripts/r16-wire-guard.js",
    "replay:failed": "node scripts/replay-failed-report.js",
    "diagnose:capture": "node scripts/diagnose-capture.js",
    "diagnose:ui": "node scripts/diagnose-ui.js",
    "diagnose:ui:specialist": "node scripts/diagnose-ui-specialist.js",
