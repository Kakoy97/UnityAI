{
  "name": "codex-unity-sidecar-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Codex-Unity sidecar gateway (Phase 6 frozen baseline)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js --port 46321",
    "start:mcp": "npm run start",
    "test": "node --test \"tests/**/*.test.js\"",
    "test:phase-d:qa": "node --test \"tests/application/r13-phase-d-closure-gate.test.js\" \"tests/application/mcp-tool-schema-minimal.test.js\" \"tests/application/r12-tool-registry-consistency.test.js\" \"tests/application/r12-tool-visibility-freeze.test.js\" \"tests/application/runtime-utils-action-data.test.js\" \"tests/application/r9-error-feedback-template-coverage.test.js\" \"tests/application/r10-token-budget-guard.test.js\" \"tests/application/r11-query-and-tools-cache.test.js\" \"tests/domain/validators.anchor-hardcut.test.js\" \"tests/domain/validators.composite-action.test.js\"",
    "test:r15:qa": "node --test \"tests/application/r10-arch-guard-scripts.test.js\" \"tests/application/r11-arch-guard-scripts.test.js\" \"tests/application/r10-responsibility-boundary.test.js\" \"tests/application/r11-responsibility-boundary.test.js\" \"tests/domain/r15-split-facade-compatibility.test.js\"",
    "test:r10:qa": "node --test \"tests/application/r10-*.test.js\" \"tests/application/capability-sync.test.js\" \"tests/domain/validators.composite-action.test.js\"",
    "smoke": "npm run smoke:mcp-job && npm run smoke:mcp-stream && npm run smoke:mcp-visual-anchor",
    "smoke:fast": "npm run smoke:mcp-job && npm run smoke:mcp-stream && npm run smoke:mcp-visual-anchor",
    "smoke:mcp-visual-anchor": "node scripts/mcp-visual-anchor-regression.js",
    "smoke:mcp-job": "node scripts/mcp-job-runner.js --base-url http://127.0.0.1:46327 --spawn-sidecar --mcp-max-queue 1",
    "smoke:mcp-stream": "node scripts/mcp-stream-runner.js --base-url http://127.0.0.1:46326 --spawn-sidecar --mcp-max-queue 1 --mcp-stream-max-events 6 --mcp-stream-max-subscribers 2 --mcp-stream-recovery-jobs-max 2",
    "gate:step8": "node scripts/step8-quality-gate.js",
    "gate:r9-closure": "node scripts/r9-closure-guard.js",
    "gate:r9-docs": "node scripts/r9-doc-index-guard.js",
    "gate:r10-responsibility": "node scripts/r10-responsibility-guard.js",
    "gate:r10-contract-snapshot": "node scripts/r10-contract-snapshot-guard.js",
    "gate:r10-docs": "node scripts/r10-doc-index-guard.js",
    "gate:r11-command-boundary": "node scripts/r11-command-boundary-guard.js",
    "replay:failed": "node scripts/replay-failed-report.js",
    "diagnose:ui": "node scripts/diagnose-ui.js",
    "metrics:step8": "node scripts/step8-quality-gate.js --skip-matrix",
    "mcp:server": "node src/mcp/mcpServer.js",
    "mcp:setup-cursor": "node scripts/setup-cursor-mcp.js",
    "mcp:verify": "node scripts/verify-mcp-setup.js"
  }
}
